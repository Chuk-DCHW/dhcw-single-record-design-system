{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "DHCW Single Record Design System — Primitive spacing tokens (Tier 1). Raw scale values based on a 4px base unit. Never reference these directly in components — use semantic tokens.",

  "space": {
    "$description": "4px base-unit spacing scale",
    "0":  { "$type": "dimension", "$value": "0px",   "$description": "Explicit zero" },
    "1":  { "$type": "dimension", "$value": "4px",   "$description": "Icon padding, micro gaps" },
    "2":  { "$type": "dimension", "$value": "8px",   "$description": "Tight component internals" },
    "3":  { "$type": "dimension", "$value": "12px",  "$description": "Compact form elements" },
    "4":  { "$type": "dimension", "$value": "16px",  "$description": "Default internal padding" },
    "5":  { "$type": "dimension", "$value": "20px" },
    "6":  { "$type": "dimension", "$value": "24px",  "$description": "Section spacing within panels" },
    "8":  { "$type": "dimension", "$value": "32px",  "$description": "Component separation" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px",  "$description": "Section breaks" },
    "16": { "$type": "dimension", "$value": "64px",  "$description": "Major layout sections" },
    "20": { "$type": "dimension", "$value": "80px",  "$description": "Page-level vertical rhythm" },
    "24": { "$type": "dimension", "$value": "96px" }
  }
}
